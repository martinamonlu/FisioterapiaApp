<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Permisos para vídeos: -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.FisioterapiaApp">

        <activity
            android:name=".CrearPlanActivity"
            android:exported="false" />

        <activity
            android:name=".SignInPacienteActivity"
            android:exported="false" />
        <activity
            android:name=".PerfilFisioActivity"
            android:exported="false" />
        <activity
            android:name=".AddPacienteActivity"
            android:exported="false" />
        <activity
            android:name=".DashboardFisioActivity"
            android:exported="false" />
        <activity
            android:name=".SignInFisioActivity"
            android:exported="false" />
        <activity
            android:name=".SignUpFisioActivity"
            android:exported="false" />
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>