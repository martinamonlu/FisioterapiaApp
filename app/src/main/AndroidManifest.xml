<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <!-- Permisos -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />

    <application
        android:name=".RehappApplication"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.FisioterapiaApp"
        android:usesCleartextTraffic="false"
        tools:targetApi="31">


        <activity
            android:name=".RehappApplication"
            android:exported="false" />
        <!-- ── Pantalla principal ── -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity> <!-- ── Fisioterapeuta ── -->
        <activity
            android:name=".SignInFisioActivity"
            android:exported="false" />
        <activity
            android:name=".SignUpFisioActivity"
            android:exported="false" />
        <activity
            android:name=".DashboardFisioActivity"
            android:exported="false" />
        <activity
            android:name=".PerfilFisioActivity"
            android:exported="false" />
        <activity
            android:name=".AddPacienteActivity"
            android:exported="false" />
        <activity
            android:name=".CrearPlanActivity"
            android:exported="false" /> <!-- ── Paciente: Autenticación (MVVM) ── -->
        <activity
            android:name=".paciente.ui.auth.SignInPacienteActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".paciente.ui.auth.CambiarPasswordActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" /> <!-- ── Paciente: Shell principal con bottom nav ── -->
        <activity
            android:name=".paciente.ui.dashboard.PacienteMainActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" /> <!-- ── Paciente: Detalle del ejercicio con vídeo ── -->
        <activity
            android:name=".paciente.ui.exercise.EjercicioDetalleActivity"
            android:exported="false"
            android:screenOrientation="portrait" /> <!-- ── Paciente: Registro post-sesión ── -->
        <activity
            android:name=".paciente.ui.registro.RegistroSesionActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" /> <!-- ── Notificaciones FCM ── -->
        <service
            android:name=".paciente.util.RehappMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>
    </application>

</manifest>