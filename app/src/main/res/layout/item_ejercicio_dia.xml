<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="4dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- Estado del ejercicio -->
        <ImageView
            android:id="@+id/ivEstado"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_pending"
            android:contentDescription="Estado" />

        <!-- Información del ejercicio -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/tvNombreEjercicio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nombre ejercicio"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/black" />

            <TextView
                android:id="@+id/tvTipoEjercicio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tipo"
                android:textSize="12sp"
                android:textColor="#757575"
                android:layout_marginTop="2dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp">

                <TextView
                    android:id="@+id/tvSeriesReps"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3×10"
                    android:textSize="13sp"
                    android:textColor="#2C7873"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvCarga"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="13sp"
                    android:textColor="#757575"
                    android:layout_marginStart="8dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Botón ver vídeo -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnVerVideo"
            style="@style/Widget.MaterialComponents.Button.Icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Vídeo"
            android:textSize="11sp"
            app:icon="@drawable/ic_play"
            app:iconSize="14dp"
            android:backgroundTint="#2C7873"
            android:visibility="gone" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
