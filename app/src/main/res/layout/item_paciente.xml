<?xml version="1.0" encoding="utf-8"?>

<!-- ITEM DE PACIENTE -->
<!-- Representa cada paciente como una tarjeta personalizada -->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"

    android:layout_width="match_parent"
    android:layout_height="wrap_content"

    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"

    app:cardBackgroundColor="#00000000"
    app:cardCornerRadius="15dp"
    app:cardElevation="0dp">

    <!--  -->

    <!-- CONTENEDOR PRINCIPAL -->
    <!-- Se usa un LinearLayout horizontal para colocar imagen + texto -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"

        android:background="@drawable/bg_paciente_item"

        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp">

        <!-- IMAGEN DEL PACIENTE -->
        <!-- Icono representativo (usa el de usericon, cambiaaaaar) -->
        <ImageView
            android:id="@+id/ivFotoPaciente"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:scaleType="centerCrop"
            app:srcCompat="@drawable/usericon" />

        <!-- NOMBRE DEL PACIENTE -->
        <!-- Se rellenará dinámicamente desde el Adapter -->
        <TextView
        android:id="@+id/tvNombrePaciente"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:text="Nombre del Paciente"
        android:textColor="#36769E"
        android:textSize="18sp"
        android:textStyle="bold" />

    </LinearLayout>

</androidx.cardview.widget.CardView>