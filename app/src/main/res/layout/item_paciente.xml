<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cardPaciente"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="6dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp"
    app:strokeWidth="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- AVATAR CON INICIALES -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardAvatar"
            android:layout_width="56dp"
            android:layout_height="56dp"
            app:cardCornerRadius="28dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/primary_teal"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <TextView
                android:id="@+id/tvIniciales"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="MP"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold"
                tools:text="MP" />

        </com.google.android.material.card.MaterialCardView>

        <!-- CONTENIDO PRINCIPAL -->
        <LinearLayout
            android:id="@+id/layoutInfo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="8dp"
            android:orientation="vertical"
            app:layout_constraintStart_toEndOf="@id/cardAvatar"
            app:layout_constraintEnd_toStartOf="@id/btnOpciones"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <!-- NOMBRE COMPLETO -->
            <TextView
                android:id="@+id/tvNombrePaciente"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="María Pérez García"
                android:textColor="@color/text_dark"
                android:textSize="17sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                tools:text="María Pérez García" />

            <!-- DIAGNÓSTICO -->
            <TextView
                android:id="@+id/tvDiagnostico"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Esguince de tobillo"
                android:textColor="@color/text_gray"
                android:textSize="14sp"
                android:maxLines="1"
                android:ellipsize="end"
                tools:text="Esguince de tobillo" />

            <!-- INFO ADICIONAL -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- INDICADOR DE ESTADO -->
                <View
                    android:id="@+id/viewEstado"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/shape_circle_indicator"
                    android:backgroundTint="@color/primary_teal" />

                <TextView
                    android:id="@+id/tvEstado"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="Plan activo"
                    android:textColor="@color/text_gray_light"
                    android:textSize="12sp"
                    tools:text="Plan activo" />

                <!-- SEPARADOR -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="8dp"
                    android:text="•"
                    android:textColor="@color/text_gray_light"
                    android:textSize="12sp" />

                <!-- ÚLTIMA SESIÓN -->
                <TextView
                    android:id="@+id/tvUltimaSesion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hoy"
                    android:textColor="@color/text_gray_light"
                    android:textSize="12sp"
                    tools:text="Hace 2 días" />

            </LinearLayout>

        </LinearLayout>

        <!-- BOTÓN OPCIONES -->
        <ImageButton
            android:id="@+id/btnOpciones"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Opciones"
            android:src="@android:drawable/ic_menu_more"
            app:tint="@color/text_gray_light"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- BADGE DE ADHERENCIA (Opcional) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardAdherencia"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/background_warning"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <TextView
                android:id="@+id/tvAdherencia"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="⚠️ 45%"
                android:textColor="@color/text_warning"
                android:textSize="11sp"
                android:textStyle="bold"
                tools:text="⚠️ 45%" />

        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>