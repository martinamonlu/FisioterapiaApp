<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light_alt"
    android:fitsSystemWindows="true"
    tools:context=".DashboardFisioActivity">

    <!-- TÍTULO CON PADDING PARA NOTCH -->
    <TextView
        android:id="@+id/tvMisPacientes"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="60dp"
        android:text="@string/title_mis_pacientes"
        android:textColor="@color/primary_blue_dark"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- BARRA DE BÚSQUEDA (OPCIONAL) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardBusqueda"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="12dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        app:layout_constraintTop_toBottomOf="@id/tvMisPacientes"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <EditText
            android:id="@+id/etBuscar"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@android:color/transparent"
            android:drawableStart="@android:drawable/ic_menu_search"
            android:drawablePadding="12dp"
            android:hint="Buscar paciente..."
            android:inputType="text"
            android:paddingHorizontal="16dp"
            android:textColor="@color/text_dark"
            android:textColorHint="@color/text_gray_light"
            android:textSize="15sp" />

    </com.google.android.material.card.MaterialCardView>

    <!-- RECYCLERVIEW DE PACIENTES -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvPacientes"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:clipToPadding="false"
        android:paddingBottom="80dp"
        app:layout_constraintTop_toBottomOf="@id/cardBusqueda"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigation"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:listitem="@layout/item_paciente" />

    <!-- BOTTOM NAVIGATION (ORIGINAL) -->
    <LinearLayout
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:background="@color/white"
        android:orientation="horizontal"
        android:weightSum="3"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageButton
            android:id="@+id/btnPerfil"
            android:layout_width="0dp"
            android:layout_height="65dp"
            android:layout_weight="1"
            android:layout_marginTop="2.5dp"
            android:padding="13.5dp"
            android:background="?attr/selectableItemBackground"
            android:contentDescription="@string/perfil"
            android:scaleType="fitCenter"
            app:srcCompat="@drawable/usericon"
            app:tint="@color/primary_blue_medium" />

        <ImageButton
            android:id="@+id/btnAddPaciente"
            android:layout_width="0dp"
            android:layout_height="65dp"
            android:layout_weight="1"
            android:layout_marginTop="3dp"
            android:padding="10dp"
            android:background="?attr/selectableItemBackground"
            android:contentDescription="@string/añadir"
            android:scaleType="fitCenter"
            app:srcCompat="@drawable/iconomas"
            app:tint="@color/primary_blue_dark" />

        <ImageButton
            android:id="@+id/btnConfig"
            android:layout_width="0dp"
            android:layout_height="65dp"
            android:layout_weight="1"
            android:layout_marginTop="3dp"
            android:padding="2dp"
            android:background="?attr/selectableItemBackground"
            android:contentDescription="@string/config"
            android:scaleType="fitCenter"
            app:srcCompat="@drawable/settings"
            app:tint="@color/primary_blue_medium" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>