<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light_alt"
    android:fitsSystemWindows="true">

    <!-- CABECERA -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:padding="16dp"
        android:paddingTop="40dp"
        android:elevation="4dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/back__v1_removebg_preview"
            android:tint="@color/primary_blue_medium"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:contentDescription="@string/volver_atras"
            android:layout_marginTop="8dp"/>

        <!-- FOTO PERFIL -->
        <ImageView
            android:id="@+id/ivFotoPaciente"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:src="@drawable/usericon"
            android:background="@drawable/circle_background"
            android:padding="12dp"
            android:tint="@color/primary_blue_medium"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/btnBack"
            android:layout_marginTop="8dp"
            android:layout_marginStart="4dp"
            android:contentDescription="@string/perfil"/>

        <!-- DATOS PACIENTE -->
        <TextView
            android:id="@+id/tvNombreCompleto"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginStart="16dp"
            app:layout_constraintStart_toEndOf="@+id/ivFotoPaciente"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/ivFotoPaciente"/>

        <TextView
            android:id="@+id/tvEmail"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:layout_marginStart="16dp"
            android:layout_marginTop="4dp"
            app:layout_constraintStart_toEndOf="@+id/ivFotoPaciente"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvNombreCompleto"/>

        <TextView
            android:id="@+id/tvDiagnostico"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="@color/text_primary"
            android:textStyle="italic"
            android:layout_marginStart="16dp"
            android:layout_marginTop="4dp"
            app:layout_constraintStart_toEndOf="@+id/ivFotoPaciente"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvEmail"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- CONTENIDO SCROLLABLE -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="200dp"
        android:layout_marginBottom="56dp"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- TARJETA CALENDARIO -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- TÍTULO SEMANA -->
                    <TextView
                        android:id="@+id/tvTituloSemana"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Plan · Semana 1/8"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp"/>

                    <!-- NAVEGACIÓN SEMANAS -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <ImageButton
                            android:id="@+id/btnSemanaAnterior"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:src="@android:drawable/ic_media_previous"
                            android:tint="@color/primary_blue_dark"
                            android:contentDescription="Semana anterior"/>

                        <TextView
                            android:id="@+id/tvRangoSemana"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp"/>

                        <ImageButton
                            android:id="@+id/btnSemanaSiguiente"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:src="@android:drawable/ic_media_next"
                            android:tint="@color/primary_blue_dark"
                            android:contentDescription="Semana siguiente"/>

                    </LinearLayout>

                    <!-- DÍAS DE LA SEMANA -->
                    <LinearLayout
                        android:id="@+id/layoutDiasCalendario"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="7">

                        <!-- L -->
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="L" android:textSize="11sp" android:textColor="@color/text_secondary" android:textStyle="bold"/>
                            <View android:id="@+id/dotLunes" android:layout_width="8dp" android:layout_height="8dp"
                                android:layout_marginTop="4dp" android:background="@drawable/circle_dot_inactive"/>
                        </LinearLayout>

                        <!-- M -->
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="M" android:textSize="11sp" android:textColor="@color/text_secondary" android:textStyle="bold"/>
                            <View android:id="@+id/dotMartes" android:layout_width="8dp" android:layout_height="8dp"
                                android:layout_marginTop="4dp" android:background="@drawable/circle_dot_inactive"/>
                        </LinearLayout>

                        <!-- X -->
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="X" android:textSize="11sp" android:textColor="@color/text_secondary" android:textStyle="bold"/>
                            <View android:id="@+id/dotMiercoles" android:layout_width="8dp" android:layout_height="8dp"
                                android:layout_marginTop="4dp" android:background="@drawable/circle_dot_inactive"/>
                        </LinearLayout>

                        <!-- J -->
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="J" android:textSize="11sp" android:textColor="@color/text_secondary" android:textStyle="bold"/>
                            <View android:id="@+id/dotJueves" android:layout_width="8dp" android:layout_height="8dp"
                                android:layout_marginTop="4dp" android:background="@drawable/circle_dot_inactive"/>
                        </LinearLayout>

                        <!-- V -->
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="V" android:textSize="11sp" android:textColor="@color/text_secondary" android:textStyle="bold"/>
                            <View android:id="@+id/dotViernes" android:layout_width="8dp" android:layout_height="8dp"
                                android:layout_marginTop="4dp" android:background="@drawable/circle_dot_inactive"/>
                        </LinearLayout>

                        <!-- S -->
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="S" android:textSize="11sp" android:textColor="@color/text_secondary" android:textStyle="bold"/>
                            <View android:id="@+id/dotSabado" android:layout_width="8dp" android:layout_height="8dp"
                                android:layout_marginTop="4dp" android:background="@drawable/circle_dot_inactive"/>
                        </LinearLayout>

                        <!-- D -->
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="D" android:textSize="11sp" android:textColor="@color/text_secondary" android:textStyle="bold"/>
                            <View android:id="@+id/dotDomingo" android:layout_width="8dp" android:layout_height="8dp"
                                android:layout_marginTop="4dp" android:background="@drawable/circle_dot_inactive"/>
                        </LinearLayout>

                    </LinearLayout>

                    <!-- BOTÓN VER DETALLE -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnVerDetalleSemana"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Ver detalle de esta semana"
                        android:textColor="@color/button_text"
                        app:backgroundTint="@color/primary_teal"/>

                    <!-- BOTÓN EDITAR PLAN -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnEditarPlan"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Editar plan"
                        android:textColor="@color/text_primary"
                        android:visibility="gone"
                        app:strokeColor="@color/text_primary"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── ESTADO DEL PACIENTE (SEMÁFORO) ── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardEstado"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <!-- Círculo semáforo -->
                    <View
                        android:id="@+id/viewSemaforo"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginEnd="14dp"
                        android:background="@drawable/circle_dot_inactive"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Estado del paciente"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/tvEstadoTexto"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_dark"
                            android:textSize="13sp"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvEvaValor"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── GRÁFICA DE EVOLUCIÓN ── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardGrafica"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Evolución (últimas sesiones)"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>

                    <com.github.mikephil.charting.charts.LineChart
                        android:id="@+id/chartEvolucionFisio"
                        android:layout_width="match_parent"
                        android:layout_height="160dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── NOTAS RECIENTES DEL PACIENTE ── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardNotas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Comentarios del paciente"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>

                    <LinearLayout
                        android:id="@+id/containerNotas"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"/>

                    <TextView
                        android:id="@+id/tvSinNotas"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="El paciente no ha dejado comentarios aún"
                        android:textColor="@color/text_gray"
                        android:textSize="13sp"
                        android:visibility="gone"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavDetalle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:layout_gravity="bottom"
        app:menu="@menu/menu_bottom_nav_detalle_paciente" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>