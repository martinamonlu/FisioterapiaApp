<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ENCABEZADO CON NÚMERO Y BOTÓN ELIMINAR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/tvNumeroEjercicio"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Ejercicio 1"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/btnEliminarEjercicio"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Eliminar ejercicio"
                android:src="@android:drawable/ic_menu_delete"
                app:tint="@color/error" />

        </LinearLayout>

        <!-- TIPO DE EJERCICIO -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tipo de ejercicio *"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/spinnerTipoEjercicio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:backgroundTint="@color/input_border"
            android:minHeight="48dp" />

        <!-- REPETICIONES -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Repeticiones *"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etRepeticiones"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:backgroundTint="@color/input_border"
            android:hint="Ej: 10"
            android:inputType="number"
            android:textColor="@color/input_text"
            android:textColorHint="@color/input_hint" />

        <!-- SERIES -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Series *"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etSeries"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:backgroundTint="@color/input_border"
            android:hint="Ej: 3"
            android:inputType="number"
            android:textColor="@color/input_text"
            android:textColorHint="@color/input_hint" />

        <!-- PESO/CARGA -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Peso/Carga"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etPeso"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:backgroundTint="@color/input_border"
            android:hint="Ej: 5kg, resistencia media..."
            android:inputType="text"
            android:textColor="@color/input_text"
            android:textColorHint="@color/input_hint" />

        <!-- FRECUENCIA -->
        <!-- DÍAS DE LA SEMANA -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Días de la semana *"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp"/>

        <LinearLayout
            android:id="@+id/layoutDiasSemana"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp"
            android:weightSum="7">

            <CheckBox
                android:id="@+id/cbLunes"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="L"
                android:textSize="12sp"
                android:textColor="@color/text_primary"
                android:buttonTint="@color/primary_teal"
                android:gravity="center"
                android:layoutDirection="rtl"/>

            <CheckBox
                android:id="@+id/cbMartes"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="M"
                android:textSize="12sp"
                android:textColor="@color/text_primary"
                android:buttonTint="@color/primary_teal"
                android:gravity="center"
                android:layoutDirection="rtl"/>

            <CheckBox
                android:id="@+id/cbMiercoles"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="X"
                android:textSize="12sp"
                android:textColor="@color/text_primary"
                android:buttonTint="@color/primary_teal"
                android:gravity="center"
                android:layoutDirection="rtl"/>

            <CheckBox
                android:id="@+id/cbJueves"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="J"
                android:textSize="12sp"
                android:textColor="@color/text_primary"
                android:buttonTint="@color/primary_teal"
                android:gravity="center"
                android:layoutDirection="rtl"/>

            <CheckBox
                android:id="@+id/cbViernes"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="V"
                android:textSize="12sp"
                android:textColor="@color/text_primary"
                android:buttonTint="@color/primary_teal"
                android:gravity="center"
                android:layoutDirection="rtl"/>

            <CheckBox
                android:id="@+id/cbSabado"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="S"
                android:textSize="12sp"
                android:textColor="@color/text_primary"
                android:buttonTint="@color/primary_teal"
                android:gravity="center"
                android:layoutDirection="rtl"/>

            <CheckBox
                android:id="@+id/cbDomingo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="D"
                android:textSize="12sp"
                android:textColor="@color/text_primary"
                android:buttonTint="@color/primary_teal"
                android:gravity="center"
                android:layoutDirection="rtl"/>

        </LinearLayout>

        <!-- VÍDEO -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Vídeo demostrativo (opcional)"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/btnSeleccionarVideo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Seleccionar vídeo"
                android:textColor="@color/button_text"
                android:textSize="14sp"
                app:backgroundTint="@color/primary_teal" />

            <TextView
                android:id="@+id/tvNombreVideo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Sin vídeo"
                android:textColor="@color/text_hint"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>