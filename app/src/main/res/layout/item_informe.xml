<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="4dp"
    app:cardCornerRadius="10dp"
    app:cardElevation="2dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- Icono PDF -->
        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_pdf"
            android:contentDescription="PDF"
            android:layout_marginEnd="12dp" />

        <!-- Información del informe -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvTituloInforme"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Informe semanal"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/black" />

            <TextView
                android:id="@+id/tvFechaInforme"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="01/01/2025"
                android:textSize="12sp"
                android:textColor="#757575"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/tvComentarioFisio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="12sp"
                android:textColor="#9E9E9E"
                android:maxLines="2"
                android:ellipsize="end"
                android:layout_marginTop="2dp"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Botón ver PDF -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnVerPdf"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ver"
            android:textSize="12sp"
            app:strokeColor="#2C7873"
            android:textColor="#2C7873"
            android:enabled="false" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
