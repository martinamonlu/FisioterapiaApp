<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F8FA">

    <ProgressBar
        android:id="@+id/progressProgreso"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tvSinDatos"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:padding="32dp"
        android:text=""
        android:textColor="#888888"
        android:textSize="15sp"
        android:visibility="gone" />

    <ScrollView
        android:id="@+id/scrollGraficas"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Resumen textual -->
            <TextView
                android:id="@+id/tvResumen"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="#E0F2F1"
                android:padding="12dp"
                android:text=""
                android:textColor="#2C7873"
                android:textSize="13sp" />

            <!-- Gráfica 1: EVA vs Carga -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Dolor (EVA) vs Carga de entrenamiento"
                android:textColor="#333333"
                android:textSize="14sp"
                android:textStyle="bold" />

            <com.github.mikephil.charting.charts.LineChart
                android:id="@+id/chartEvaVsCarga"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginBottom="24dp" />

            <!-- Gráfica 2: Adherencia por semana -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Adherencia semanal (%)"
                android:textColor="#333333"
                android:textSize="14sp"
                android:textStyle="bold" />

            <com.github.mikephil.charting.charts.BarChart
                android:id="@+id/chartAdherencia"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginBottom="24dp" />

            <!-- Gráfica 3: RPE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Esfuerzo percibido (RPE – Borg)"
                android:textColor="#333333"
                android:textSize="14sp"
                android:textStyle="bold" />

            <com.github.mikephil.charting.charts.LineChart
                android:id="@+id/chartRpe"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginBottom="16dp" />

        </LinearLayout>
    </ScrollView>
</FrameLayout>
