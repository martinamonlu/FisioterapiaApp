<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <!-- AppBar con vídeo -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:theme="@style/ThemeOverlay.MaterialComponents.Dark.ActionBar">

        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:layout_width="match_parent"
            android:layout_height="220dp"
            app:layout_scrollFlags="scroll|exitUntilCollapsed"
            app:contentScrim="#2C7873">

            <!-- Player de vídeo ExoPlayer -->
            <androidx.media3.ui.PlayerView
                android:id="@+id/playerView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#000000"
                app:show_buffering="when_playing"
                app:use_controller="true"
                app:resize_mode="fit"
                app:layout_collapseMode="parallax" />

            <!-- Placeholder cuando no hay vídeo -->
            <LinearLayout
                android:id="@+id/layoutSinVideo"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:background="#2C7873"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎯"
                    android:textSize="48sp" />

                <TextView
                    android:id="@+id/tvSinVideo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sin vídeo de demostración"
                    android:textSize="16sp"
                    android:textColor="#CCFFFFFF"
                    android:layout_marginTop="8dp" />

            </LinearLayout>

            <!-- Toolbar encima -->
            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:background="@android:color/transparent"
                app:layout_collapseMode="pin"
                app:navigationIcon="@drawable/ic_home"
                app:navigationIconTint="@android:color/white"
                app:title="" />

        </com.google.android.material.appbar.CollapsingToolbarLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Contenido scrollable -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Card principal: nombre y parámetros -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvNombreEjercicio"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nombre del ejercicio"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#2C7873" />

                    <TextView
                        android:id="@+id/tvTipoEjercicio"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tipo de ejercicio"
                        android:textSize="14sp"
                        android:textColor="#757575"
                        android:layout_marginTop="4dp" />

                    <!-- Divisor -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#E0E0E0"
                        android:layout_marginVertical="12dp" />

                    <!-- Grid de parámetros -->
                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="2"
                        android:rowCount="3">

                        <!-- Series -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="SERIES"
                                android:textSize="10sp"
                                android:textColor="#9E9E9E"
                                android:letterSpacing="0.1" />

                            <TextView
                                android:id="@+id/tvSeries"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="3"
                                android:textSize="28sp"
                                android:textStyle="bold"
                                android:textColor="#2C7873" />

                        </LinearLayout>

                        <!-- Repeticiones -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="REPETICIONES"
                                android:textSize="10sp"
                                android:textColor="#9E9E9E"
                                android:letterSpacing="0.1" />

                            <TextView
                                android:id="@+id/tvRepeticiones"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="10"
                                android:textSize="28sp"
                                android:textStyle="bold"
                                android:textColor="#2C7873" />

                        </LinearLayout>

                        <!-- Carga -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="CARGA"
                                android:textSize="10sp"
                                android:textColor="#9E9E9E"
                                android:letterSpacing="0.1" />

                            <TextView
                                android:id="@+id/tvCarga"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="— kg"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                android:textColor="#2C7873" />

                        </LinearLayout>

                        <!-- Frecuencia -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="FRECUENCIA"
                                android:textSize="10sp"
                                android:textColor="#9E9E9E"
                                android:letterSpacing="0.1" />

                            <TextView
                                android:id="@+id/tvFrecuencia"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="— /sem"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="#2C7873" />

                        </LinearLayout>

                    </GridLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Card descripción -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDescripcion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Descripción"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#424242"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tvDescripcion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="14sp"
                        android:textColor="#616161"
                        android:lineSpacingMultiplier="1.4" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ── Card de registro de la sesión ── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardRegistro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Registro de esta sesión"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#2C7873"
                        android:layout_marginBottom="16dp"/>

                    <!-- Estado: ya completado hoy -->
                    <LinearLayout
                        android:id="@+id/layoutCompletado"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="#F0FAF9"
                        android:padding="12dp"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="✓ Completado hoy"
                            android:textColor="#2C7873"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp"/>

                        <TextView
                            android:id="@+id/tvResumenCompletado"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#555555"
                            android:textSize="13sp"/>

                    </LinearLayout>

                    <!-- Formulario de registro -->
                    <LinearLayout
                        android:id="@+id/layoutFormRegistro"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Series -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="12dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Series realizadas"
                                android:textColor="#424242"
                                android:textSize="14sp"/>

                            <ImageButton
                                android:id="@+id/btnMenosSeries"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:background="@drawable/circle_background"
                                android:src="@android:drawable/ic_input_delete"
                                android:contentDescription="Menos series"
                                app:tint="#2C7873"/>

                            <TextView
                                android:id="@+id/tvSeriesVal"
                                android:layout_width="48dp"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:textColor="#2C7873"
                                android:text="3"/>

                            <ImageButton
                                android:id="@+id/btnMasSeries"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:background="@drawable/circle_background"
                                android:src="@android:drawable/ic_input_add"
                                android:contentDescription="Más series"
                                app:tint="#2C7873"/>
                        </LinearLayout>

                        <!-- Repeticiones -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="12dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Repeticiones por serie"
                                android:textColor="#424242"
                                android:textSize="14sp"/>

                            <ImageButton
                                android:id="@+id/btnMenosReps"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:background="@drawable/circle_background"
                                android:src="@android:drawable/ic_input_delete"
                                android:contentDescription="Menos reps"
                                app:tint="#2C7873"/>

                            <TextView
                                android:id="@+id/tvRepsVal"
                                android:layout_width="48dp"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:textColor="#2C7873"
                                android:text="10"/>

                            <ImageButton
                                android:id="@+id/btnMasReps"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:background="@drawable/circle_background"
                                android:src="@android:drawable/ic_input_add"
                                android:contentDescription="Más reps"
                                app:tint="#2C7873"/>
                        </LinearLayout>

                        <!-- Peso / carga -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Peso / carga usada"
                            android:textColor="#424242"
                            android:textSize="14sp"
                            android:layout_marginBottom="4dp"/>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            app:boxStrokeColor="#2C7873">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etPesoRealizado"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Ej: 5 kg, banda media, sin carga..."
                                android:inputType="text"/>
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Dolor EVA -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="4dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Dolor durante el ejercicio"
                                android:textColor="#424242"
                                android:textSize="14sp"/>

                            <TextView
                                android:id="@+id/tvEvaValEjercicio"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 – Sin dolor"
                                android:textColor="#2C7873"
                                android:textSize="13sp"
                                android:textStyle="bold"/>
                        </LinearLayout>

                        <SeekBar
                            android:id="@+id/seekEvaEjercicio"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:max="10"
                            android:progress="0"
                            android:progressTint="#2C7873"
                            android:thumbTint="#2C7873"
                            android:layout_marginBottom="20dp"/>

                        <!-- Botón completar -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCompletarEjercicio"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:text="Marcar como completado"
                            android:textSize="16sp"
                            android:backgroundTint="#2C7873"
                            app:cornerRadius="12dp"/>

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Botón volver -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAtras"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Volver al plan"
                android:backgroundTint="#2C7873"
                app:cornerRadius="10dp" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
