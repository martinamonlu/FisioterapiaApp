<?xml version="1.0" encoding="utf-8"?>

<!-- PANTALLA: AÑADIR NUEVO PACIENTE -->
<!-- Funcionalidad I: formulario para registrar un paciente nuevo -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#c2d1ce"
    tools:context=".AddPacienteActivity">

    <!-- BOTÓN ATRÁS -->
    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/volver_atras"
        android:scaleType="fitCenter"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/back__v1_removebg_preview"
        app:tint="#36769E" />

    <!-- TÍTULO -->
    <TextView
        android:id="@+id/tvTituloAdd"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="75dp"
        android:layout_marginStart="16dp"
        android:text="@string/title_add_paciente"
        android:textColor="#36769E"
        android:textSize="26sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- CARD CON EL FORMULARIO -->
    <!-- ScrollView permite desplazarse si el contenido no cabe en pantalla -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvTituloAdd"
        app:layout_constraintBottom_toTopOf="@id/btnGuardarPaciente"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- NOMBRE -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_nombre"
                    android:textColor="#36769E"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etNombrePaciente"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:backgroundTint="#547F9B"
                    android:hint="@string/hint_nombre"
                    android:inputType="textPersonName|textCapWords"
                    android:textColor="#36769E"
                    android:textColorHint="#728E8D" />

                <!-- APELLIDOS -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_apellidos"
                    android:textColor="#36769E"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etApellidosPaciente"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:backgroundTint="#547F9B"
                    android:hint="@string/hint_apellidos"
                    android:inputType="textPersonName|textCapWords"
                    android:textColor="#36769E"
                    android:textColorHint="#728E8D" />

                <!-- FECHA DE NACIMIENTO -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_fecha_nac"
                    android:textColor="#36769E"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etFechaNacPaciente"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:backgroundTint="#547F9B"
                    android:hint="@string/hint_fecha_nac"
                    android:inputType="date"
                    android:textColor="#36769E"
                    android:textColorHint="#728E8D" />

                <!-- DNI -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_dni"
                    android:textColor="#36769E"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etDniPaciente"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:backgroundTint="#547F9B"
                    android:hint="@string/hint_dni_paciente"
                    android:inputType="text"
                    android:textColor="#36769E"
                    android:textColorHint="#728E8D" />

                <!-- EMAIL -->
                <EditText
                    android:id="@+id/etEmailPaciente"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Email del paciente *"
                    android:inputType="textEmailAddress"
                    android:layout_marginTop="16dp" />

                <!-- TELÉFONO -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_telefono"
                    android:textColor="#36769E"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etTelefonoPaciente"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:backgroundTint="#547F9B"
                    android:hint="@string/hint_telefono"
                    android:inputType="phone"
                    android:textColor="#36769E"
                    android:textColorHint="#728E8D" />

                <!-- DIAGNÓSTICO / LESIÓN (desplegable) -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_diagnostico"
                    android:textColor="#36769E"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <Spinner
                    android:id="@+id/spinnerDiagnostico"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:backgroundTint="#547F9B"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </ScrollView>

    <!-- BOTÓN GUARDAR (anclado en la parte inferior) -->
    <Button
        android:id="@+id/btnGuardarPaciente"
        android:layout_width="280dp"
        android:layout_height="60dp"
        android:layout_marginBottom="24dp"
        android:text="@string/btn_guardar_paciente"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        app:backgroundTint="#547F9B"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>