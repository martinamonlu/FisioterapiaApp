<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="32dp"
        android:paddingBottom="32dp"
        android:paddingHorizontal="16dp">

        <!-- Cabecera -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <ImageButton
                android:id="@+id/btnAtras"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/back__v1_removebg_preview"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Volver" />

            <TextView
                android:id="@+id/tvTitulo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="Registro de sesión"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/black" />

        </LinearLayout>

        <!-- 1. Sesión completada -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Sesión completada"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/black" />

                <CheckBox
                    android:id="@+id/checkSesionCompletada"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="#2C7873" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- 2. Carga externa -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/layoutCargaExterna"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:visibility="gone"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Carga externa"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:layout_marginBottom="12dp" />

                <!-- Series -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Series completadas"
                        android:textSize="14sp"
                        android:textColor="#424242" />

                    <ImageButton
                        android:id="@+id/btnMenosSeries"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@android:drawable/ic_input_delete"
                        android:background="@drawable/shape_circle_green"
                        android:contentDescription="Menos series" />

                    <TextView
                        android:id="@+id/tvSeriesVal"
                        android:layout_width="40dp"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:textColor="@color/black" />

                    <ImageButton
                        android:id="@+id/btnMasSeries"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@android:drawable/ic_input_add"
                        android:background="@drawable/shape_circle_green"
                        android:contentDescription="Más series" />

                </LinearLayout>

                <!-- Repeticiones -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Repeticiones completadas"
                        android:textSize="14sp"
                        android:textColor="#424242" />

                    <ImageButton
                        android:id="@+id/btnMenosReps"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@android:drawable/ic_input_delete"
                        android:background="@drawable/shape_circle_green"
                        android:contentDescription="Menos reps" />

                    <TextView
                        android:id="@+id/tvRepsVal"
                        android:layout_width="40dp"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:textColor="@color/black" />

                    <ImageButton
                        android:id="@+id/btnMasReps"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@android:drawable/ic_input_add"
                        android:background="@drawable/shape_circle_green"
                        android:contentDescription="Más reps" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- 3. Carga interna: EVA -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Carga interna"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dolor (EVA)"
                    android:textSize="14sp"
                    android:textColor="#424242" />

                <TextView
                    android:id="@+id/tvEvaVal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 – Sin dolor"
                    android:textSize="13sp"
                    android:textColor="#2C7873"
                    android:layout_marginTop="2dp" />

                <SeekBar
                    android:id="@+id/seekEva"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="10"
                    android:progress="0"
                    android:progressTint="#2C7873"
                    android:thumbTint="#2C7873"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Esfuerzo percibido (RPE Borg)"
                    android:textSize="14sp"
                    android:textColor="#424242" />

                <TextView
                    android:id="@+id/tvRpeVal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="6 – Sin esfuerzo"
                    android:textSize="13sp"
                    android:textColor="#2C7873"
                    android:layout_marginTop="2dp" />

                <SeekBar
                    android:id="@+id/seekRpe"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="14"
                    android:progress="0"
                    android:progressTint="#2C7873"
                    android:thumbTint="#2C7873" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- 4. Molestias y observaciones -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Molestias / Observaciones"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/etNotas"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:hint="Escribe aquí cualquier molestia, incidencia u observación..."
                    android:inputType="textMultiLine"
                    android:gravity="top"
                    android:background="@android:color/transparent"
                    android:textSize="14sp"
                    android:textColor="@color/black"
                    android:textColorHint="#BDBDBD" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ProgressBar guardar -->
        <ProgressBar
            android:id="@+id/progressGuardar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:visibility="gone"
            android:layout_marginBottom="8dp" />

        <!-- 5. Botón guardar -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGuardar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Guardar registro"
            android:textSize="16sp"
            android:backgroundTint="#2C7873"
            app:cornerRadius="12dp" />

    </LinearLayout>

</ScrollView>