<?xml version="1.0" encoding="utf-8"?>

<!-- PANTALLA: PERFIL DEL FISIOTERAPEUTA -->
<!-- Funcionalidad II: ver y editar datos personales del fisio -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#c2d1ce"
    tools:context=".PerfilFisioActivity">

    <!-- BOTÓN ATRÁS -->
    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/volver_atras"
        android:scaleType="fitCenter"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/back__v1_removebg_preview"
        app:tint="#36769E" />

    <!-- TÍTULO -->
    <TextView
        android:id="@+id/tvTituloPerfil"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="75dp"
        android:layout_marginStart="16dp"
        android:text="@string/title_mi_perfil"
        android:textColor="#36769E"
        android:textSize="26sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- BOTÓN EDITAR -->
    <ImageButton
        android:id="@+id/btnEdit"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/editar_perfil"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@android:drawable/ic_menu_edit"
        app:tint="#36769E" />

    <!-- CARD PERFIL -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardPerfil"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="6dp"
        app:layout_constraintTop_toBottomOf="@id/tvTituloPerfil"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- NOMBRE -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_nombre_colon"
                    android:textSize="18sp"
                    android:textColor="#36769E"
                    android:textStyle="bold"/>

                <EditText
                    android:id="@+id/etNombre"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/placeholder_nombre_fisio"
                    android:textSize="18sp"
                    android:textColor="#36769E"
                    android:enabled="false"
                    android:background="@android:color/transparent"/>
            </LinearLayout>

            <!-- APELLIDOS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_apellidos_colon"
                    android:textSize="18sp"
                    android:textColor="#36769E"
                    android:textStyle="bold"/>

                <EditText
                    android:id="@+id/etApellidos"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/placeholder_apellidos_fisio"
                    android:textSize="18sp"
                    android:textColor="#36769E"
                    android:enabled="false"
                    android:background="@android:color/transparent"/>
            </LinearLayout>

            <!-- FECHA NACIMIENTO -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_fecha_nac_colon"
                    android:textSize="18sp"
                    android:textColor="#36769E"
                    android:textStyle="bold"/>

                <EditText
                    android:id="@+id/etNacimiento"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/placeholder_fecha_fisio"
                    android:textSize="18sp"
                    android:textColor="#36769E"
                    android:enabled="false"
                    android:background="@android:color/transparent"/>
            </LinearLayout>

            <!-- Nº COLEGIADO -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_colegiado_colon"
                    android:textSize="18sp"
                    android:textColor="#36769E"
                    android:textStyle="bold"/>

                <EditText
                    android:id="@+id/etColegiado"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/placeholder_colegiado_fisio"
                    android:textSize="18sp"
                    android:textColor="#36769E"
                    android:enabled="false"
                    android:background="@android:color/transparent"/>
            </LinearLayout>

            <!-- ESPECIALIDAD -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_especialidad_colon"
                    android:textSize="18sp"
                    android:textColor="#36769E"
                    android:textStyle="bold"/>

                <EditText
                    android:id="@+id/etEspecialidad"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/placeholder_especialidad_fisio"
                    android:textSize="18sp"
                    android:textColor="#36769E"
                    android:enabled="false"
                    android:background="@android:color/transparent"/>
            </LinearLayout>

            <!-- EMAIL -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_email_colon"
                    android:textSize="18sp"
                    android:textColor="#36769E"
                    android:textStyle="bold"/>

                <EditText
                    android:id="@+id/etEmail"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/placeholder_email_fisio"
                    android:textSize="18sp"
                    android:textColor="#36769E"
                    android:inputType="textEmailAddress"
                    android:enabled="false"
                    android:background="@android:color/transparent"/>
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- BOTÓN GUARDAR (sólo visible en modo edición) -->
    <Button
        android:id="@+id/btnGuardarPerfil"
        android:layout_width="280dp"
        android:layout_height="60dp"
        android:layout_marginBottom="24dp"
        android:text="@string/btn_guardar_perfil"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        app:backgroundTint="#547F9B"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:visibility="gone" />

</androidx.constraintlayout.widget.ConstraintLayout>