<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- ===================== COLORES PRINCIPALES ===================== -->
    <!-- Paleta de color principal de Rehapp: tonos azul-verde agua -->

    <color name="primary_blue_dark">#36769E</color>      <!-- Azul oscuro - títulos, textos importantes -->
    <color name="primary_blue_medium">#547F9B</color>    <!-- Azul medio - botones principales, bordes -->
    <color name="primary_teal">#5FA19D</color>           <!-- Verde agua - títulos alternativos -->
    <color name="primary_teal_light">#7AB5B2</color>     <!-- Verde agua claro - botones secundarios -->

    <!-- ===================== COLORES DE FONDO ===================== -->

    <color name="background_light">#c2d1ce</color>       <!-- Fondo principal verde agua muy claro -->
    <color name="white">#FFFFFF</color>                  <!-- Blanco - fondos de tarjetas, texto en botones -->

    <!-- ===================== COLORES DE TEXTO ===================== -->

    <color name="text_primary">#36769E</color>           <!-- Texto principal (mismo que primary_blue_dark) -->
    <color name="text_secondary">#547F9B</color>         <!-- Texto secundario (mismo que primary_blue_medium) -->
    <color name="text_hint">#728E8D</color>              <!-- Hints en campos de texto -->
    <color name="text_on_primary">#FFFFFF</color>        <!-- Texto sobre botones/fondos oscuros -->

    <!-- ===================== COLORES DE ESTADO ===================== -->

    <color name="error">#FF0000</color>                  <!-- Rojo - errores, validaciones -->
    <color name="black">#000000</color>                  <!-- Negro - uso general si necesario -->

    <!-- ===================== COLORES SEMÁNTICOS ===================== -->
    <!-- Alias para facilitar cambios futuros sin tocar todos los XMLs -->

    <color name="button_background">#547F9B</color>      <!-- Color de fondo de botones principales -->
    <color name="button_background_alt">#7AB5B2</color>  <!-- Color de fondo de botones alternativos -->
    <color name="button_text">#FFFFFF</color>            <!-- Color de texto en botones -->

    <color name="input_border">#547F9B</color>           <!-- Color de bordes de campos de entrada -->
    <color name="input_text">#36769E</color>             <!-- Color de texto en campos de entrada -->
    <color name="input_hint">#728E8D</color>             <!-- Color de hints en campos de entrada -->

    <color name="title_text">#36769E</color>             <!-- Color de títulos principales -->
    <color name="title_text_alt">#5FA19D</color>         <!-- Color de títulos alternativos -->

</resources>